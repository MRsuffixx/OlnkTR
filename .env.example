# Generate with: pnpm exec auth secret
AUTH_SECRET=""

# Google OAuth (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# SMTP connection URL used for passwordless email links
EMAIL_SERVER="smtp://username:password@smtp.example.com:587"
EMAIL_FROM="olnk <giris@olnk.tr>"

DATABASE_URL="postgresql://postgres:password@localhost:5432/OlnkTR"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Billing: a provider is only enabled when every required value for it is present.
# Stripe and Adyen charge the canonical USD prices ($3 monthly / $22 yearly).
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# iyzico subscriptions charge fixed TRY prices. Values are kuruş (e.g. 12900 = ₺129).
IYZICO_API_KEY=""
IYZICO_SECRET_KEY=""
IYZICO_BASE_URL="https://api.iyzipay.com"
# These plan codes must point to catalog prices matching the TRY amounts below.
IYZICO_MONTHLY_PLAN_CODE=""
IYZICO_YEARLY_PLAN_CODE=""

# PayTR uses hosted iFrame payments for manually renewed Pro terms (no stored card handling).
PAYTR_MERCHANT_ID=""
PAYTR_MERCHANT_KEY=""
PAYTR_MERCHANT_SALT=""
PAYTR_TEST_MODE="1"

# Both local providers require explicit fixed TRY prices; no volatile FX conversion at checkout.
LOCAL_PRO_MONTHLY_TRY="12900"
LOCAL_PRO_YEARLY_TRY="94900"

ADYEN_API_KEY=""
ADYEN_MERCHANT_ACCOUNT=""
ADYEN_HMAC_KEY=""
ADYEN_API_URL="https://checkout-test.adyen.com/v72"
ADYEN_RECURRING_URL="https://pal-test.adyen.com/pal/servlet/Recurring/v68"
NEXT_PUBLIC_ADYEN_CLIENT_KEY=""
NEXT_PUBLIC_ADYEN_ENVIRONMENT="test"

# Secures the renewal endpoint used for tokenized Adyen recurring charges.
CRON_SECRET=""

# Optional S3-compatible uploads for avatars/backgrounds.
STORAGE_ENDPOINT=""
STORAGE_REGION="auto"
STORAGE_BUCKET=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_PUBLIC_URL=""
